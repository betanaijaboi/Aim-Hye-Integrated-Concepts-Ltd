generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Brewery {
  id        String    @id @default(cuid())
  name      String    @unique
  shortName String
  logoUrl   String?
  products  Product[]
  purchaseOrders PurchaseOrder[]
  createdAt DateTime  @default(now())
}

model Product {
  id             String   @id @default(cuid())
  name           String
  sku            String   @unique
  breweryId      String
  brewery        Brewery  @relation(fields: [breweryId], references: [id])
  category       String   // lager, stout, malt, spirits, rtd, wine
  size           String   // 33cl, 60cl, 1L, 75cl, 35cl
  packSize       Int      // bottles per crate/pack
  pricePerCrate  Float
  pricePerBottle Float
  depositPerCrate Float   @default(0) // empty bottle deposit value per crate
  stockCrates    Int      @default(0)
  minStockCrates Int      @default(5)
  packaging      String   @default("glass") // glass | can | pet
  productFamily  String?                    // slug grouping variants, e.g. "star-lager"
  branch         String   @default("IKOT_EKPENE") // IKOT_EKPENE | ITAM
  imageUrl       String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  orderItems         OrderItem[]
  truckAllocations   TruckAllocation[]
  emptyReturns       EmptyReturn[]
  stockLogs          StockLog[]
  cartItems          CartItem[]
  customerOrderItems CustomerOrderItem[]
  purchaseOrderItems PurchaseOrderItem[]
  goodsReceiptItems  GoodsReceiptItem[]
  changeRequests     ManagerChangeRequest[]
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String?
  address   String
  lga       String?
  state     String   @default("Nigeria")
  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  orders    Order[]
}

model Order {
  id              String      @id @default(cuid())
  orderNo         String      @unique
  customerId      String
  customer        Customer    @relation(fields: [customerId], references: [id])
  status          String      @default("PENDING") // PENDING, CONFIRMED, DISPATCHED, DELIVERED, CANCELLED
  totalAmount     Float
  depositAmount   Float       @default(0)
  notes           String?
  deliveryAddress String
  assignedTruckId String?
  assignedTruck   Truck?      @relation(fields: [assignedTruckId], references: [id])
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  items           OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int     // in crates
  unitPrice Float
  subtotal  Float
}

model Truck {
  id          String   @id @default(cuid())
  plateNumber String   @unique
  make        String
  model       String
  year        Int
  color       String?
  capacity    Int      @default(200) // max crates
  isActive    Boolean  @default(true)
  notes       String?
  createdAt   DateTime @default(now())

  driver      Driver?
  salesboy    Salesboy?
  allocations TruckAllocation[]
  orders      Order[]
  emptyReturns EmptyReturn[]
}

model Driver {
  id             String    @id @default(cuid())
  truckId        String?   @unique
  truck          Truck?    @relation(fields: [truckId], references: [id])
  firstName      String
  lastName       String
  phone          String
  alternatePhone String?
  address        String
  lga            String?
  state          String?
  nin            String?
  licenseNo      String?
  licenseExpiry  DateTime?
  photoUrl       String?
  ninDocUrl      String?
  licenseDocUrl  String?
  isActive       Boolean   @default(true)
  startDate      DateTime?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  guarantors Guarantor[]
}

model Salesboy {
  id             String    @id @default(cuid())
  truckId        String?   @unique
  truck          Truck?    @relation(fields: [truckId], references: [id])
  firstName      String
  lastName       String
  phone          String
  alternatePhone String?
  address        String
  lga            String?
  state          String?
  nin            String?
  photoUrl       String?
  ninDocUrl      String?
  isActive       Boolean   @default(true)
  startDate      DateTime?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  guarantors Guarantor[]
}

model Guarantor {
  id           String    @id @default(cuid())
  driverId     String?
  driver       Driver?   @relation(fields: [driverId], references: [id])
  salespersonId String?
  salesboy     Salesboy? @relation(fields: [salespersonId], references: [id])
  name         String
  phone        String
  address      String
  occupation   String?
  relationship String?
  letterUrl    String?
  createdAt    DateTime  @default(now())
}

// Daily truck stock loading
model TruckAllocation {
  id           String   @id @default(cuid())
  truckId      String
  truck        Truck    @relation(fields: [truckId], references: [id])
  productId    String
  product      Product  @relation(fields: [productId], references: [id])
  date         DateTime @default(now())
  cratesLoaded Int
  cratesReturn Int      @default(0)
  cratesSold   Int      @default(0)
  pricePerCrate Float
  totalValue   Float    @default(0)
  amountRemitted Float  @default(0)
  notes        String?
  status       String   @default("LOADED") // LOADED, RETURNED, RECONCILED
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Empties returned by truck
model EmptyReturn {
  id             String   @id @default(cuid())
  truckId        String
  truck          Truck    @relation(fields: [truckId], references: [id])
  productId      String
  product        Product  @relation(fields: [productId], references: [id])
  date           DateTime @default(now())
  cratesReturned Int      @default(0)
  looseBottles   Int      @default(0)
  totalBottles   Int      @default(0)
  depositValue   Float    @default(0)
  notes          String?
  createdAt      DateTime @default(now())
}

// Stock movement log
model StockLog {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  prevQty   Int
  newQty    Int
  change    Int
  reason    String   // EVENING_UPDATE, TRUCK_LOAD, TRUCK_RETURN, PURCHASE, ADJUSTMENT
  reference String?  // allocation ID, order ID, etc.
  notes     String?
  createdAt DateTime @default(now())
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("STAFF") // ADMIN, STAFF, MANAGER
  branch    String?  // IKOT_EKPENE | ITAM — required for MANAGER role
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  raisedPOs        PurchaseOrder[]       @relation("RaisedPOs")
  approvedPOs      PurchaseOrder[]       @relation("ApprovedPOs")
  purchasePayments PurchasePayment[]
  goodsReceipts    GoodsReceipt[]
  changeRequests   ManagerChangeRequest[] @relation("ManagerRequests")
  reviewedChanges  ManagerChangeRequest[] @relation("ReviewedChanges")
}

model ManagerChangeRequest {
  id            String     @id @default(cuid())
  requestedById String
  requestedBy   AdminUser  @relation("ManagerRequests", fields: [requestedById], references: [id])
  type          String     // STOCK_UPDATE | PRICE_CHANGE
  productId     String
  product       Product    @relation(fields: [productId], references: [id])
  branch        String     @default("IKOT_EKPENE") // IKOT_EKPENE | ITAM
  currentValue  Float
  proposedValue Float
  reason        String
  status        String     @default("PENDING") // PENDING | APPROVED | REJECTED
  reviewedById  String?
  reviewedBy    AdminUser? @relation("ReviewedChanges", fields: [reviewedById], references: [id])
  reviewNote    String?
  reviewedAt    DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

// Customer account system
model CustomerAccount {
  id            String    @id @default(cuid())
  name          String
  phone         String    @unique
  email         String?   @unique
  password      String?
  pin           String?   // bcrypt-hashed 4-digit payment PIN
  isActive      Boolean   @default(true)
  emailVerified Boolean   @default(false)
  phoneVerified Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  addresses    CustomerAddress[]
  cartItems    CartItem[]
  orders       CustomerOrder[]
  otps         OTP[]
  savedCards   SavedCard[]
  webAuthnCreds WebAuthnCredential[]
  payments     Payment[]
}

model CustomerAddress {
  id         String          @id @default(cuid())
  customerId String
  customer   CustomerAccount @relation(fields: [customerId], references: [id])
  label      String          @default("Home")
  address    String
  lga        String?
  state      String?
  isDefault  Boolean         @default(false)
  createdAt  DateTime        @default(now())
}

model CartItem {
  id         String          @id @default(cuid())
  customerId String
  customer   CustomerAccount @relation(fields: [customerId], references: [id])
  productId  String
  product    Product         @relation(fields: [productId], references: [id])
  quantity   Int
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@unique([customerId, productId])
}

model SavedCard {
  id           String          @id @default(cuid())
  customerId   String
  customer     CustomerAccount @relation(fields: [customerId], references: [id])
  paystackAuth String
  last4        String
  brand        String
  expMonth     String
  expYear      String
  email        String
  isDefault    Boolean         @default(false)
  createdAt    DateTime        @default(now())
}

model OTP {
  id         String          @id @default(cuid())
  customerId String
  customer   CustomerAccount @relation(fields: [customerId], references: [id])
  code       String
  purpose    String          // LOGIN, PAYMENT, PIN_RESET, REGISTER
  expiresAt  DateTime
  usedAt     DateTime?
  attempts   Int             @default(0)
  createdAt  DateTime        @default(now())
}

model WebAuthnCredential {
  id           String          @id @default(cuid())
  customerId   String
  customer     CustomerAccount @relation(fields: [customerId], references: [id])
  credentialId String          @unique
  publicKey    String
  counter      Int             @default(0)
  deviceType   String?
  aaguid       String?
  createdAt    DateTime        @default(now())
}

model CustomerOrder {
  id              String          @id @default(cuid())
  orderNo         String          @unique
  customerId      String
  customer        CustomerAccount @relation(fields: [customerId], references: [id])
  status          String          @default("PENDING")
  branch          String          @default("IKOT_EKPENE") // IKOT_EKPENE | ITAM
  totalAmount     Float
  depositAmount   Float           @default(0)
  deliveryAddress String
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  items    CustomerOrderItem[]
  payment  Payment?
}

model CustomerOrderItem {
  id        String        @id @default(cuid())
  orderId   String
  order     CustomerOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product       @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Float
  subtotal  Float
}

model Payment {
  id          String          @id @default(cuid())
  customerId  String
  customer    CustomerAccount @relation(fields: [customerId], references: [id])
  orderId     String          @unique
  order       CustomerOrder   @relation(fields: [orderId], references: [id])
  method      String          // PAYSTACK_CARD, PAYSTACK_TRANSFER, BANK_TRANSFER
  status      String          @default("PENDING") // PENDING, SUCCESS, FAILED, REFUNDED
  amount      Float
  reference   String          @unique
  paystackRef String?
  bankProofUrl String?
  verifiedAt  DateTime?
  metadata    String?         // JSON string for extra data
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

// ─── Procurement / Purchase Order System ────────────────────────────────────

model PurchaseOrder {
  id         String   @id @default(cuid())
  poNumber   String   @unique  // e.g. PO-20240618-001
  breweryId  String
  brewery    Brewery  @relation(fields: [breweryId], references: [id])
  raisedById String   // AdminUser id
  raisedBy   AdminUser @relation("RaisedPOs", fields: [raisedById], references: [id])
  approvedById String?
  approvedBy   AdminUser? @relation("ApprovedPOs", fields: [approvedById], references: [id])

  status      String  @default("DRAFT")
  // DRAFT → PENDING_APPROVAL → APPROVED → PAID → PARTIALLY_RECEIVED → RECEIVED → CLOSED → CANCELLED

  notes       String?
  expectedAt  DateTime?  // expected delivery date
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  items        PurchaseOrderItem[]
  payment      PurchasePayment?
  receipts     GoodsReceipt[]
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  quantityOrdered Int
  unitCost        Float         // cost per crate from brewery
  totalCost       Float
}

model PurchasePayment {
  id              String        @id @default(cuid())
  purchaseOrderId String        @unique
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  amountPaid      Float
  bankName        String?
  accountName     String?
  transferRef     String?       // bank transfer reference / teller number
  paidAt          DateTime
  paidById        String        // AdminUser id of who recorded the payment
  paidBy          AdminUser     @relation(fields: [paidById], references: [id])
  notes           String?
  createdAt       DateTime      @default(now())
}

model GoodsReceipt {
  id              String        @id @default(cuid())
  receiptNumber   String        @unique  // GR-20240618-001
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  receivedById    String        // AdminUser who recorded the receipt
  receivedBy      AdminUser     @relation(fields: [receivedById], references: [id])
  receivedAt      DateTime      @default(now())
  notes           String?
  isPartial       Boolean       @default(false)
  createdAt       DateTime      @default(now())

  items  GoodsReceiptItem[]
}

model GoodsReceiptItem {
  id             String       @id @default(cuid())
  goodsReceiptId String
  goodsReceipt   GoodsReceipt @relation(fields: [goodsReceiptId], references: [id], onDelete: Cascade)
  productId      String
  product        Product      @relation(fields: [productId], references: [id])
  quantityOrdered   Int
  quantityReceived  Int
  quantityShortfall Int       @default(0)  // ordered - received
}
